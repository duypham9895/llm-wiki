# stage 1: build
FROM --platform=linux/amd64 node:22-alpine AS build
WORKDIR /src
COPY package.json package-lock.json ./
# npm 10.9 (ships with node:22-alpine) has bug #4828 — optionalDependencies
# are not reliably installed for native bindings (rolldown, lightningcss, etc.)
# Upgrade to npm 11 first as the actual root-cause fix.
RUN npm install -g npm@11 --no-audit --no-fund && \
    npm ci --no-audit --no-fund
COPY . .
RUN npm run build

# stage 2: runtime — carries the bundle only
FROM caddy:2-alpine
COPY --from=build /src/dist /srv
