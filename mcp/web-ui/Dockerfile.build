# stage 1: build
FROM node:22-alpine AS build
WORKDIR /src
COPY package.json package-lock.json ./
# Use `npm i` (not `npm ci`) because rolldown ships its native binding
# (linux-x64-musl, linux-arm64-musl, etc.) as an optionalDependency, and
# npm ci has a known bug (npm/cli#4828) where it sometimes fails to install
# optional deps. `npm i` re-resolves and reliably installs the binding.
RUN npm i --no-audit --no-fund
COPY . .
RUN npm run build

# stage 2: runtime — carries the bundle only
FROM caddy:2-alpine
COPY --from=build /src/dist /srv
