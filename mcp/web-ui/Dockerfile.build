# stage 1: build
FROM --platform=linux/amd64 node:22-alpine AS build
WORKDIR /src
COPY package.json package-lock.json ./
# npm has a bug (npm/cli#4828) where optionalDependencies are not
# reliably installed for rolldown's native binding on linux-musl platforms.
# Workaround: explicit install of the matching binding after `npm i`.
# TARGETOS is auto-set by docker buildx (linux).
ARG TARGETOS=linux
ARG TARGETARCH=amd64
RUN npm i --no-audit --no-fund && \
    npm i --no-audit --no-fund @rolldown/binding-${TARGETOS}-${TARGETARCH}-musl
COPY . .
RUN npm run build

# stage 2: runtime — carries the bundle only
FROM caddy:2-alpine
COPY --from=build /src/dist /srv
