{
    email {$CADDY_EMAIL}
    auto_https off
}

:80 {
    encode zstd gzip

    # All paths flow through handle blocks. Explicit handles win first; the
    # catch-all `handle` at the bottom serves the SPA with try_files fallback
    # for client-side routes (/library, /ask, etc.).
    #
    # Why handle blocks? Without them, `try_files` at the site level runs
    # BEFORE any reverse_proxy matcher and rewrites unknown paths to
    # /index.html, swallowing /api/* requests (returning 405 on POST because
    # the rewritten path doesn't match any API matcher).

    # SSE/streaming — disable buffering so chat tokens flush as they arrive.
    # Real path is POST /api/chat/conversations/{cid}/messages (sse_starlette.EventSourceResponse).
    handle /api/chat/conversations/*/messages {
        reverse_proxy prd-app:8300 {
            flush_interval -1
        }
    }

    # All other API paths. We use a path matcher with a regex to match any depth
    # — Caddy's /api/** glob surprisingly only matches single-segment paths in
    # v2.11 (likely a bug; the docs say it should match across segments).
    @api path_regexp ^/api(/|$)
    handle @api {
        reverse_proxy prd-app:8300
    }

    handle /healthz {
        reverse_proxy prd-app:8300
    }

    # Catch-all: SPA static files with try_files fallback for client-side routes.
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}