{
    email {$CADDY_EMAIL}
    auto_https off
}

:80 {
    encode zstd gzip

    # API + healthcheck are reverse-proxied to the backend. We MUST use explicit
    # handle blocks here so they match BEFORE try_files/file_server can rewrite
    # the path to /index.html (which would otherwise swallow /api/* requests
    # into the SPA shell, causing 405 on POST /api/auth/login etc.).

    # SSE/streaming — disable buffering so chat tokens flush as they arrive.
    # Real path is POST /api/chat/conversations/{cid}/messages (sse_starlette.EventSourceResponse).
    handle /api/chat/conversations/**/messages {
        reverse_proxy prd-app:8300 {
            flush_interval -1
        }
    }

    # All other API paths.
    handle /api/** {
        reverse_proxy prd-app:8300
    }

    handle /healthz {
        reverse_proxy prd-app:8300
    }

    # Everything else: static SPA (volume-mounted at /srv). try_files makes
    # client-side routes like /library resolve to index.html.
    root * /srv
    try_files {path} /index.html
    file_server
}