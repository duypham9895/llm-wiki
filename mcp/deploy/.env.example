# Copy to .env, fill real values, chmod 600. NEVER commit .env.
# Postgres (compose builds DATABASE_URL host = service name prd-postgres)
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgresql+asyncpg://prd_app:change-me-strong@prd-postgres:5432/prd_auth

# Bootstrap admin (break-glass; rotate out of .env after first login if desired)
ADMIN_EMAIL=duy@ringkas.co.id
ADMIN_PASSWORD=change-me-strong-admin-pw

# First-boot-only seeds (DB authoritative thereafter)
REGISTRATION_ENABLED=false
ALLOWED_EMAIL_DOMAINS=ringkas.co.id

# Session + security knobs (defaults shown)
SESSION_IDLE_HOURS=24
SESSION_ABSOLUTE_DAYS=30
LAST_SEEN_THROTTLE_MIN=5
RATE_LIMIT_PER_MIN=5
PASSWORD_MIN_LENGTH=12

# Deployment
ENV=prod
# On VPS, set to https://${HOSTNAME} (the new Caddy-fronted URL).
CORS_ORIGIN=https://prd.duyopenclaw.tech
# NO COOKIE_SECRET (opaque tokens — not signed).

# ── Phase 3 (HTTP door + pipeline) ──────────────────────────────────────────
# The `prd-mcp web` command now builds the shared PRD core (cfg/store/llm) so the
# dashboard's Library/Search/Ask/Status work — so LLM/embed keys ARE needed here
# (scoped to this container; see the Phase-3 spec §8 blast-radius tradeoff).
PRD_SECRETS=env                       # use env-backed secret readers (not macOS keychain)
VAULT_PATH=/data/vault                # the Obsidian vault dir (PRDs/ + .runs/ live here)
CHROMA_PATH=/data/vault/.chroma-mcp   # optional; defaults to <vault>/.chroma-mcp
OPENAI_API_KEY=change-me              # embeddings (read via env_secret under PRD_SECRETS=env)
# Pipeline (A/B) secrets — only on the box that runs the orchestrator (npm run orchestrate):
NOTION_TOKEN=change-me                # stage A (Notion sync)
LLM_API_KEY=change-me                 # stage B enrich + the Ask tab's chat (MiniMax)
LLM_BASE_URL=https://9router-1.dat-nguyen.me/v1
LLM_MODEL=minimax/MiniMax-M3
# REQUEST_TIMEOUT / MAX_RETRIES default to 60 / 3 — keep REQUEST_TIMEOUT×(MAX_RETRIES+1)
# well below the chat stale-lock sweep cutoff (6 h) — see prd_mcp/web/chat.py.

# ── VPS deploy additions ─────────────────────────────────────────────────────
# Pinned image tag for app + webui. Set to a git SHA on VPS, "latest" only for first boot.
IMAGE_TAG=latest

# Hostname Caddy will serve + request a Let's Encrypt cert for. REPLACE before first VPS deploy.
HOSTNAME=wiki.example.com

# Email for Let's Encrypt account registration.
CADDY_EMAIL=duypham9895@users.noreply.github.com

# healthchecks.io dead-man's-notify ping URL (backup cron pings on success). Create one at healthchecks.io, paste the URL here.
BACKUP_HEALTHCHECK_URL=https://hc-ping.com/00000000-0000-0000-0000-000000000000
